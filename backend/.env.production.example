# CapMan AI — Production Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# ─── Required ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...          # Anthropic Claude API key
FMP_API_KEY=...                              # Financial Modeling Prep API key
SECRET_KEY=generate-a-random-32-char-key     # JWT signing key (python -c "import secrets; print(secrets.token_urlsafe(32))")
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/capman

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=https://your-frontend.vercel.app  # Comma-separated allowed origins

# ─── Optional ──────────────────────────────────────────────
LOG_LEVEL=INFO                               # DEBUG, INFO, WARNING, ERROR

# LangSmith (LLM observability — leave empty to disable)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=                           # Get from https://smith.langchain.com
LANGCHAIN_PROJECT=capman-ai

# OpenRouter (alternative LLM provider — leave false unless switching)
USE_OPENROUTER=false
OPENROUTER_API_KEY=
