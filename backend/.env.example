# CapMan AI Environment Variables

# ─── Required API Keys ────────────────────────────────────
# 1. Anthropic (Claude) — LLM for scenarios, probing, grading
#    Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 2. Financial Modeling Prep — Real options/stock market data
#    Get yours at: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# ─── LangSmith (LLM Observability & Cost Tracing) ────────
# Get yours at: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=capman-ai
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─── OpenRouter (Alternative — use instead of direct Anthropic) ─
# Get yours at: https://openrouter.ai/keys
# Set USE_OPENROUTER=true to use OpenRouter instead of direct Anthropic
USE_OPENROUTER=false
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── Atlas — CapMan Internal Production Market Data API ──
# When USE_ATLAS=true, Atlas replaces FMP+Yahoo as the data source
# Atlas provides: real-time quotes, options chains, historical OHLCV, vol analytics
USE_ATLAS=false
ATLAS_API_KEY=your_atlas_api_key_here
ATLAS_BASE_URL=https://atlas.capman.io/api/v1

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./capman.db

# ─── Auth ─────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here

# ─── App Mode ────────────────────────────────────────────────
# Set to true for local development (enables /docs, allows default SECRET_KEY)
DEBUG=true

# ─── Logging ───────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ─── Trusted Hosts (production only) ───────────────────────
# TRUSTED_HOSTS=capman.yourdomain.com,api.yourdomain.com

# ─── Performance (Docker only) ─────────────────────────────
# WEB_CONCURRENCY=4
